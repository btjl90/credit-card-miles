# Cloudflare
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token

# Google Sheets (for admin sync)
GOOGLE_SHEETS_API_KEY=your_api_key
GOOGLE_SHEETS_ID=your_spreadsheet_id

# Gemini API key (free tier: https://aistudio.google.com/apikey)
# Used by the T&C monitor to parse PDF terms — no cost for ~20 PDFs/month
GOOGLE_API_KEY=your_gemini_api_key

# T&C Monitor — Discord webhook for alerts (free, no domain needed)
# See Discord setup guide: src/lib/tc-alerts.ts header
TC_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# Admin auth
JWT_SECRET=your_jwt_secret
